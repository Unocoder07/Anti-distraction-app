<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#1A1A1A"
    android:padding="32dp">

    <!-- Shield Icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛡️"
        android:textSize="80sp"
        android:layout_marginBottom="24dp" />

    <!-- Blocked App Name -->
    <TextView
        android:id="@+id/blockedAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App Blocked"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <!-- Time Remaining -->
    <TextView
        android:id="@+id/timeRemaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="30 minutes remaining"
        android:textSize="16sp"
        android:textColor="#14B8A6"
        android:layout_marginBottom="32dp" />

    <!-- Blocked Message -->
    <TextView
        android:id="@+id/blockedMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This app is blocked during your focus session."
        android:textSize="16sp"
        android:textColor="#9CA3AF"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        android:lineSpacingMultiplier="1.3" />

    <!-- Return to Focus Button -->
    <Button
        android:id="@+id/returnToFocusButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="✅ Return to Focus"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_primary"
        android:layout_marginBottom="12dp" />

    <!-- Break Session Button -->
    <Button
        android:id="@+id/breakSessionButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="❌ Break Session (-50 FP)"
        android:textSize="14sp"
        android:textColor="#EF4444"
        android:background="@drawable/button_secondary"
        android:layout_marginBottom="24dp" />

    <!-- Info Text -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This screen will close automatically in 3 seconds"
        android:textSize="12sp"
        android:textColor="#6B7280"
        android:gravity="center" />

</LinearLayout>
